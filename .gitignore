# R standard ignores
.Rhistory
.RData
.Rproj.user
*.Rproj
.Rcheck/

# Package build
*.tar.gz
*.so
*.dll

# Data directories — do not commit downloaded or extracted data
data/raw/
data/extracted/
output/

# Auto-generated example outputs. Students who want to commit these
# as a record of their specific run can `git add` them explicitly,
# overriding the gitignore.
data/file_inventory.rds
data/my_sites.csv
data/my_manifest.csv

# OS cruft
.DS_Store
Thumbs.db
